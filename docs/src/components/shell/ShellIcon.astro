---
type IconName =
  | "home"
  | "bolt"
  | "layers"
  | "code"
  | "link"
  | "sparkles"
  | "cloud"
  | "user"
  | "life"
  | "file"
  | "download"
  | "message"
  | "arrow"
  | "lock";

const { name, class: className = "" } = Astro.props as {
  name: IconName;
  class?: string;
};

const paths: Record<IconName, string[]> = {
  home: ["M3 11.5 12 4l9 7.5", "M5.5 10.5V20h13v-9.5", "M9.5 20v-5h5v5"],
  bolt: ["M13 2 4 14h7l-1 8 10-13h-7l0-7Z"],
  layers: ["m12 3 8 4-8 4-8-4 8-4Z", "m4 12 8 4 8-4", "m4 17 8 4 8-4"],
  code: ["m8 9-4 3 4 3", "m16 9 4 3-4 3", "m14 5-4 14"],
  link: ["M10 13a5 5 0 0 0 7.1.2l2-2a5 5 0 0 0-7.1-7.1l-1.1 1.1", "M14 11a5 5 0 0 0-7.1-.2l-2 2A5 5 0 0 0 12 19.9l1.1-1.1"],
  sparkles: ["M12 3l1.7 5.3L19 10l-5.3 1.7L12 17l-1.7-5.3L5 10l5.3-1.7L12 3Z", "M19 16l.8 2.2L22 19l-2.2.8L19 22l-.8-2.2L16 19l2.2-.8L19 16Z"],
  cloud: ["M7 18h10a4 4 0 0 0 .7-7.9A6 6 0 0 0 6.3 8.7 4.7 4.7 0 0 0 7 18Z", "M12 13v6", "m9 16 3-3 3 3"],
  user: ["M20 21a8 8 0 0 0-16 0", "M12 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z"],
  life: ["M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20Z", "M8.5 8.5l7 7", "M15.5 8.5l-7 7", "M7 12h10"],
  file: ["M6 3h8l4 4v14H6V3Z", "M14 3v5h5", "M9 13h6", "M9 17h6"],
  download: ["M12 3v11", "m7 10 5 5 5-5", "M5 21h14"],
  message: ["M4 5h16v11H8l-4 4V5Z"],
  arrow: ["M5 12h14", "m13 6 6 6-6 6"],
  lock: ["M7 11V8a5 5 0 0 1 10 0v3", "M6 11h12v10H6V11Z"],
};
---

<svg
  class:list={["shell-icon", className]}
  viewBox="0 0 24 24"
  aria-hidden="true"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  {paths[name].map((d) => <path d={d} />)}
</svg>

