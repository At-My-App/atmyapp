---
import JokeCard from "../components/JokeCard.astro";
import { jokes, siteSettings } from "../data/jokes";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={`Archive | ${siteSettings.title}`} description="Previous jokes from the AtMyApp starter.">
  <section class="mx-auto w-full max-w-6xl px-5 pb-16 pt-8 sm:px-8 lg:pb-24 lg:pt-16">
    <div class="max-w-2xl">
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ama-accent)]">
        Collection example
      </p>
      <h1 class="text-4xl font-semibold tracking-normal text-[var(--ama-ink)] sm:text-5xl">
        Joke archive
      </h1>
      <p class="mt-5 text-lg leading-8 text-[var(--ama-muted)]">
        This page renders a small collection. In a real project, these records can come from AtMyApp.
      </p>
    </div>
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      {jokes.map((joke) => <JokeCard joke={joke} />)}
    </div>
  </section>
</BaseLayout>
