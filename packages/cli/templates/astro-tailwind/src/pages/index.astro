---
import JokeCard from "../components/JokeCard.astro";
import { siteSettings, todaysJoke } from "../data/jokes";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title={siteSettings.title} description={siteSettings.description}>
  <section class="mx-auto grid w-full max-w-6xl gap-8 px-5 pb-16 pt-8 sm:px-8 lg:grid-cols-[1fr_0.78fr] lg:items-center lg:pb-24 lg:pt-16">
    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.18em] text-[var(--ama-accent)]">
        Static Astro + AtMyApp
      </p>
      <h1 class="max-w-3xl text-5xl font-semibold leading-[1.02] tracking-normal text-[var(--ama-ink)] sm:text-6xl">
        A starter that is tiny, typed, and ready for real content.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[var(--ama-muted)]">
        Replace the local sample data with AtMyApp content when your project is ready.
        The schema, commands, pages, and layout are already in place.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href="/archive/">View archive</a>
        <a class="button-secondary" href="https://docs.atmyapp.com">Read docs</a>
      </div>
    </div>
    <JokeCard joke={todaysJoke} featured />
  </section>
</BaseLayout>
